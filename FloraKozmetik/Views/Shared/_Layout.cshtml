<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FLORA</title>

    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/css/pages.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
    <link rel="stylesheet" href="~/css/profile.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- CUSTOM CURSOR -->
    <div class="cursor" id="cur"></div>
    <div class="cursor-ring" id="curRing"></div>

    <!-- CSRF TOKEN -->
    @Html.AntiForgeryToken()

    <!-- DUYURU ÇUBUĞU -->
    <div class="announce" id="announceBar">
        <div class="announce-inner">
            <span>🌿 500₺ üzeri ücretsiz kargo</span>
            <span>✦</span>
            <span>💄 Yeni sezon koleksiyonu geldi</span>
            <span>✦</span>
            <span>🎁 İlk siparişte %15 indirim: FLORA15</span>
        </div>
        <button class="announce-close" id="announceClose">✕</button>
    </div>

    <!-- NAVİGASYON -->
    <nav>
    <input type="text" style="display:none" />
    <input type="password" style="display:none" />
            <div class="nav-top">
                <div></div>
                <a href="@Url.Action("Index", "Home")" class="nav-logo">FLORA</a>
            <div class="nav-icons">
                @if (User.IsInRole("Admin"))
                {
                    <a href="@Url.Action("Index", "Admin")" class="admin-panel-btn" title="Admin Panel">
                        Admin Panel
                    </a>
                }
                else if (User.Identity!.IsAuthenticated)
                {
                    <a href="@Url.Action("Index", "Account")" class="nav-icon-btn" title="Hesabım">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    </a>
                    <a href="@Url.Action("Index", "Favorite")" class="nav-icon-btn" title="Favorilerim" style="position:relative">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
                        <span class="icon-badge" id="favBadge" style="display:none">0</span>
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="nav-icon-btn" title="Giriş Yap">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    </a>
                }

                @if (!User.IsInRole("Admin"))
                {
                    <button class="nav-icon-btn" title="Sepetim" onclick="openCartDrawer()" style="position:relative">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                        <span class="icon-badge" id="cartBadge" style="display:none">0</span>
                    </button>
                }
            </div>
            </div>

        <div class="nav-bottom">
            <a href="@Url.Action("Index", "Home")"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                Ana Sayfa
            </a>
            <a href="@Url.Action("Index", "Products", new { category = "skincare" })"
               class="nav-link @(ViewBag.Category == "skincare" ? "active" : "")">
                Yüz Bakımı
            </a>
            <a href="@Url.Action("Index", "Products", new { category = "fragrances" })"
               class="nav-link @(ViewBag.Category == "fragrances" ? "active" : "")">
                Parfümler
            </a>
            <a href="@Url.Action("Index", "Products", new { category = "beauty" })"
               class="nav-link @(ViewBag.Category == "beauty" ? "active" : "")">
                Makyaj
            </a>
            <a href="@Url.Action("Index", "Deals")" class="nav-link sale">Fırsatlar</a>
        </div>
    </nav>

    <!-- SAYFA İÇERİĞİ -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="footer-main">
            <div>
                <div class="ft-logo">FLORA</div>
                <p class="ft-desc">
                    Doğanın en saf özlerinden ilham alan bakım ürünleriyle güzelliğinizi keşfedin.
                    Sürdürülebilir, etik, etkili.
                </p>
            </div>
            <div>
                <p class="ft-col-title">Alışveriş</p>
                <ul class="ft-links">
                    <li><a href="#">Yeni Ürünler</a></li>
                    <li><a href="#">Çok Satanlar</a></li>
                    <li><a href="#">Fırsatlar</a></li>
                </ul>
            </div>
            <div>
                <p class="ft-col-title">Kategoriler</p>
                <ul class="ft-links">
                    <li><a href="@Url.Action("Index", "Products", new { category = "skincare" })">Yüz Bakımı</a></li>
                    <li><a href="@Url.Action("Index", "Products", new { category = "fragrances" })">Parfümler</a></li>
                    <li><a href="@Url.Action("Index", "Products", new { category = "beauty" })">Makyaj</a></li>
                </ul>
            </div>
            <div>
                <p class="ft-col-title">Yardım</p>
                <ul class="ft-links">
                    <li><a href="#">SSS</a></li>
                    <li><a href="#">Kargo Takip</a></li>
                    <li><a href="#">İade &amp; Değişim</a></li>
                    <li><a href="#">İletişim</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="ft-copy">© @DateTime.Now.Year Flora Kozmetik — Tüm hakları saklıdır.</p>
            <div class="ft-pay">
                <span class="pay-icon">VISA</span>
                <span class="pay-icon">MC</span>
                <span class="pay-icon">TROY</span>
            </div>
            <p class="ft-copy">Gizlilik · KVKK · Çerez Politikası</p>
        </div>
    </footer>

    <!-- SEPET DRAWER -->
    <div class="drawer-overlay" id="drawerOverlay" onclick="closeCartDrawer()"></div>
    <div class="cart-drawer" id="cartDrawer">
        <div class="cart-drawer-head">
            <h3>Sepetim</h3>
            <button class="cart-drawer-close" onclick="closeCartDrawer()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="cart-drawer-body" id="cartDrawerBody"></div>
        <div class="cart-drawer-footer" style="display:none">
            <div class="cart-drawer-total">
                <span>Toplam</span>
                <span class="cart-total-price">₺0</span>
            </div>
            <a href="/Order/Checkout" class="cart-drawer-checkout">Ödemeye Geç</a>
            <button class="cart-drawer-continue" onclick="closeCartDrawer()">Alışverişe Devam Et</button>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

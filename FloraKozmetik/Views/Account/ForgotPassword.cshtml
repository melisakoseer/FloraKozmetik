@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">FLORA</div>
        </div>
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:400;margin:0 0 8px">Şifremi Unuttum</h2>
        <p style="font-size:13px;color:#999;margin:0 0 28px">E-posta adresinizi ve yeni şifrenizi girin.</p>

        <div class="form-group">
            <label>E-posta</label>
            <input type="email" class="form-input" id="email" placeholder="ornek@email.com" />
        </div>
        <div class="form-group">
            <label>Yeni Şifre</label>
            <input type="password" class="form-input" id="newPassword" placeholder="En az 6 karakter" />
        </div>
        <div class="form-group">
            <label>Yeni Şifre (Tekrar)</label>
            <input type="password" class="form-input" id="newPassword2" />
        </div>

        <div id="resultMsg" style="display:none;font-size:13px;margin-bottom:12px;padding:10px;border-radius:8px"></div>

        <button class="auth-btn" onclick="resetPassword()">Şifremi Sıfırla</button>

        <div class="auth-footer">
            Şifreni hatırladın mı? <a href="@Url.Action("Login", "Account")">Giriş Yap</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/forget-password.js"></script>
}
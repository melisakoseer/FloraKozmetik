@model FloraKozmetik.Models.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card auth-card-wide">

        <div class="auth-header">
            <h1 class="auth-logo">FLORA</h1>
            <p class="auth-subtitle">Yeni hesap oluştur</p>
        </div>

        <form asp-action="Register" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-error"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName">Ad</label>
                    <input asp-for="FirstName" class="form-input" placeholder="Adınız" />
                    <span asp-validation-for="FirstName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName">Soyad</label>
                    <input asp-for="LastName" class="form-input" placeholder="Soyadınız" />
                    <span asp-validation-for="LastName" class="field-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Email">E-posta</label>
                <input asp-for="Email" class="form-input" placeholder="ornek@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber">Telefon</label>
                <input asp-for="PhoneNumber" class="form-input" placeholder="05xx xxx xx xx" />
                <span asp-validation-for="PhoneNumber" class="field-error"></span>
            </div>

            <div class="form-group">
                <label>Doğum Tarihi</label>
                <div class="birth-row">
                    <select asp-for="BirthDay" class="form-input">
                        <option value="">Gün</option>
                        @for (int i = 1; i <= 31; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                    <select asp-for="BirthMonth" class="form-input">
                        <option value="">Ay</option>
                        @{
                            var months = new[] { "Ocak","Şubat","Mart","Nisan","Mayıs","Haziran","Temmuz","Ağustos","Eylül","Ekim","Kasım","Aralık" };
                            for (int i = 0; i < 12; i++)
                            {
                                <option value="@(i+1)">@months[i]</option>
                            }
                        }
                    </select>
                    <select asp-for="BirthYear" class="form-input">
                        <option value="">Yıl</option>
                        @for (int y = DateTime.Now.Year - 13; y >= 1940; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <span asp-validation-for="BirthDay" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Gender">Cinsiyet</label>
                <select asp-for="Gender" class="form-input">
                    <option value="">Seçiniz</option>
                    <option value="Kadın">Kadın</option>
                    <option value="Erkek">Erkek</option>
                    <option value="Belirtmek istemiyorum">Belirtmek istemiyorum</option>
                </select>
                <span asp-validation-for="Gender" class="field-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Password">Şifre</label>
                    <div class="input-eye-wrap">
                        <input asp-for="Password" class="form-input" id="regPassword" placeholder="••••••" />
                        <button type="button" class="eye-btn" onclick="togglePass('regPassword', this)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmPassword">Şifre Tekrar</label>
                    <div class="input-eye-wrap">
                        <input asp-for="ConfirmPassword" class="form-input" id="regPassword2" placeholder="••••••" />
                        <button type="button" class="eye-btn" onclick="togglePass('regPassword2', this)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
            </div>

            <button type="submit" class="auth-btn">Kayıt Ol</button>
        </form>

        <div class="auth-footer">
            <p>Zaten hesabın var mı? <a asp-action="Login" asp-controller="Account">Giriş Yap</a></p>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function togglePass(id) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
}

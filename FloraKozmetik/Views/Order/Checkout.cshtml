@using FloraKozmetik.Models
@{
    ViewData["Title"] = "Ödeme";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cartItems = ViewBag.CartItems as List<CartItem> ?? new List<CartItem>();
    var addresses = ViewBag.Addresses as List<Address> ?? new List<Address>();
    var user = ViewBag.User as ApplicationUser;
    decimal subtotal = cartItems.Sum(c => c.Product!.Price * c.Quantity);
}

<div class="breadcrumb">
    <a href="@Url.Action("Index", "Home")">Ana Sayfa</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">Ödeme</span>
</div>

<div class="checkout-layout">
    <!-- SOL: FORM -->
    <div class="checkout-left">

        <!-- ADRES -->
        <div class="checkout-section">
            <h2 class="checkout-section-title">
                <span class="checkout-step">1</span>
                Teslimat Adresi
            </h2>
            <div class="address-options">
                @foreach (var addr in addresses)
                {
                    <label class="address-option">
                        <input type="radio" name="addressId" value="@addr.Id"
                               @(addr.IsDefault ? "checked" : "") />
                        <div class="address-option-body">
                            <div class="address-option-head">
                                <span class="address-option-title">@addr.Title</span>
                                @if (addr.IsDefault)
                                {
                                    <span class="address-default-badge">Varsayılan</span>
                                }
                            </div>
                            <p class="address-option-text">@addr.FullName</p>
                            <p class="address-option-text">@addr.FullAddress, @addr.District/@addr.City</p>
                            <p class="address-option-text">@addr.Phone</p>
                        </div>
                    </label>
                }
                <label class="address-option">
                    <input type="radio" name="addressId" value="0" id="newAddressRadio"
                           @(!addresses.Any() ? "checked" : "") />
                    <div class="address-option-body">
                        <span class="address-option-title">+ Yeni Adres Ekle</span>
                    </div>
                </label>
            </div>
            <!-- YENİ ADRES FORMU -->
           <div class="new-address-form" id="newAddressForm" style=@(addresses.Any() ? "display:none" : "")>
                <div class="checkout-form-grid">
                    <div class="checkout-form-group">
                        <label>Adres Başlığı</label>
                        <input type="text" class="profile-input" id="newAddressTitle" placeholder="Ev, İş..." />
                    </div>
                    <div class="checkout-form-group">
                        <label>Ad Soyad</label>
                        <input type="text" class="profile-input" id="newAddressFullName"
                              />
                    </div>
                    <div class="checkout-form-group">
                        <label>Telefon</label>
                        <input type="tel" class="profile-input" id="newAddressPhone" placeholder="05xx xxx xx xx" />
                    </div>
                    <div class="checkout-form-group">
                        <label>Şehir</label>
                        <input type="text" class="profile-input" id="newAddressCity"/>
                    </div>
                    <div class="checkout-form-group">
                        <label>İlçe</label>
                        <input type="text" class="profile-input" id="newAddressDistrict"/>
                    </div>
                    <div class="checkout-form-group" style="grid-column:1/-1">
                        <label>Açık Adres</label>
                        <textarea class="profile-input" id="newAddressFullAddress" rows="3"
                                  placeholder="Mahalle, sokak, bina no, daire no..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- ÖDEME -->
        <div class="checkout-section">
            <h2 class="checkout-section-title">
                <span class="checkout-step">2</span>
                Ödeme Bilgileri
            </h2>

            <div class="payment-methods">
                <label class="payment-option active" id="pm-card">
                    <input type="radio" name="paymentMethod" value="Kredi Kartı" checked />
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                    </svg>
                    Kredi / Banka Kartı
                </label>
            </div>

            <div class="card-form" id="cardForm">
                <div class="checkout-form-group" style="margin-top:20px">
                    <label>Kart Üzerindeki İsim</label>
                    <input type="text" class="profile-input" id="cardName"
                           placeholder="Ad Soyad"
                          />
                </div>
                <div class="checkout-form-group">
                    <label>Kart Numarası</label>
                    <div class="card-input-wrap">
                        <input type="text" class="profile-input" id="cardNumber"
                               placeholder="0000 0000 0000 0000"
                               maxlength="19"
                              />
                        <div class="card-icons">
                            <span class="card-icon visa">VISA</span>
                        </div>
                    </div>
                </div>
                <div class="checkout-form-row">
                    <div class="checkout-form-group">
                        <label>Son Kullanma</label>
                        <input type="text" class="profile-input" id="cardExpiry"
                               placeholder="AA/YY" maxlength="5"
                              />
                    </div>
                    <div class="checkout-form-group">
                        <label>CVV</label>
                        <input type="text" class="profile-input" id="cardCvv"
                               placeholder="123" maxlength="3" />
                    </div>
                </div>
            </div>
        </div>

        <!-- KUPON -->
        <div class="checkout-section">
            <h2 class="checkout-section-title">
                <span class="checkout-step">3</span>
                İndirim Kodu
            </h2>
            <div class="coupon-input-wrap">
                <input type="text" class="profile-input" id="couponInput"
                       placeholder="Kupon kodunuzu girin (FLORA15)" />
                <button class="coupon-apply-btn" onclick="applyCoupon()">Uygula</button>
            </div>
            <div class="coupon-result" id="couponResult" style="display:none"></div>
        </div>
    </div>

    <!-- SAĞ: SİPARİŞ ÖZETİ -->
    <div class="checkout-right">
        <div class="order-summary">
            <h3 class="order-summary-title">Sipariş Özeti</h3>

            <div class="order-summary-items">
                @foreach (var item in cartItems)
                {
                    <div class="order-summary-item">
                        <img src="@item.Product!.ImageUrl" alt="@item.Product.Name" class="order-summary-img" />
                        <div class="order-summary-item-info">
                            <p class="order-summary-item-name">@item.Product.Name</p>
                            <p class="order-summary-item-qty">x@item.Quantity</p>
                        </div>
                        <span class="order-summary-item-price">₺@((item.Product.Price * item.Quantity).ToString("N0"))</span>
                    </div>
                }
            </div>

            <div class="order-summary-totals">
                <div class="order-summary-row">
                    <span>Ara Toplam</span>
                    <span id="summarySubtotal">₺@subtotal.ToString("N0")</span>
                </div>
                <div class="order-summary-row">
                    <span>Kargo</span>
                    <span class="order-free-shipping">@(subtotal >= 500 ? "Ücretsiz" : "₺49")</span>
                </div>
                <div class="order-summary-row discount-row" id="discountRow" style="display:none">
                    <span>İndirim</span>
                    <span class="order-discount-amount" id="discountAmount">-₺0</span>
                </div>
                <div class="order-summary-divider"></div>
                <div class="order-summary-row total-row">
                    <span>Toplam</span>
                    <span id="summaryTotal">₺@((subtotal + (subtotal >= 500 ? 0 : 49)).ToString("N0"))</span>
                </div>
            </div>

            <button class="checkout-submit-btn" onclick="placeOrder()">
                Siparişi Tamamla
            </button>
            <p class="checkout-secure-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                256-bit SSL ile güvenli ödeme
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.CHECKOUT_SUBTOTAL = @subtotal;//checkout.js ayrı bir dosya olduğu için subtotal Razor değişkenine erişemiyor. 
        //Bu satır Razor'dan JS'e subtotal değerini aktarıyor — checkout.js içinde window.CHECKOUT_SUBTOTAL olarak kullanıyoruz kupon hesabı ve toplam güncelleme için.
    </script>
    <script src="~/js/checkout.js?v=@DateTime.Now.Ticks"></script>
}

